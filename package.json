{
  "name": "nestjs-project",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:dev": "node scripts/with-node-env.cjs development nest build",
    "build:prod": "node scripts/with-node-env.cjs production nest build",
    "db:down": "docker compose -f ../compose.yaml stop postgres redis redisinsight",
    "db:logs": "docker compose -f ../compose.yaml logs -f postgres redis redisinsight",
    "db:ps": "docker compose -f ../compose.yaml ps postgres redis redisinsight",
    "db:up": "docker compose -f ../compose.yaml up -d postgres redis redisinsight",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:env": "node scripts/with-node-env.cjs development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:prod:env": "node scripts/with-node-env.cjs production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:erd": "node scripts/prisma-erd.cjs",
    "prisma:erd:svg": "node_modules\\.bin\\mmdc.cmd -i prisma/ERD.mmd -o prisma/ERD.svg -q",
    "prisma:erd:all": "npm run prisma:erd && npm run prisma:erd:svg",
    "prisma:generate": "prisma generate",
    "prisma:generate:dev": "node scripts/with-node-env.cjs development prisma generate",
    "prisma:generate:prod": "node scripts/with-node-env.cjs production prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:dev": "node scripts/with-node-env.cjs development prisma migrate dev",
    "prisma:migrate:prod": "node scripts/with-node-env.cjs production prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "x-script-notes": {
    "build": "Build app; dev/prod variants ep NODE_ENV cho dung env file.",
    "db:*": "Quan ly Postgres local bang Docker Compose.",
    "start:*": "Chay NestJS o che do thuong, watch, debug, hoac production.",
    "test:*": "Chay unit test, watch test, coverage, va debug test.",
    "prisma:erd*": "Sinh so do ERD tu Prisma schema.",
    "prisma:generate*": "Sinh lai Prisma Client/types theo schema.prisma.",
    "prisma:migrate*": "Dong bo schema vao database; dev dung migrate dev, prod dung migrate deploy.",
    "prisma:studio": "Mo Prisma Studio de xem/sua du lieu local."
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "prisma-erd-generator-markdown": "^1.3.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}



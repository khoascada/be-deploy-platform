# This file is a fallback template.
# The app and Prisma now prefer:
# - .env.development when NODE_ENV=development
# - .env.production when NODE_ENV=production
# and fall back to .env if the env-specific file does not exist.

NODE_ENV=development
PORT=3000

# Postgres (local Docker)
POSTGRES_DB=deploy_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deploy_platform?schema=public"

# JWT
JWT_SECRET="thay-bang-chuoi-toi-thieu-16-ky-tu"
JWT_EXPIRES_IN=7d

# Frontend and CORS
CORS_ORIGIN=http://localhost:2805
FRONTEND_URL=http://localhost:2805

# Redis
REDIS_URL=redis://localhost:6379

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/github/oauth/callback
GITHUB_OAUTH_SCOPE=read:user repo
# Base64-encoded 32-byte key. Generate a separate secret per environment.
GITHUB_TOKEN_ENCRYPTION_KEY=

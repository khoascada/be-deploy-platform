generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum Theme {
  LIGHT
  DARK
}

enum Language {
  VI
  EN
}

enum RunnerType {
  LOCAL
  SSH
}

enum GithubConnectionStatus {
  /// Đang connect bình thường
  CONNECTED
  /// Token bị user revoke từ GitHub hoặc không còn dùng được
  REVOKED
  /// Có lỗi khi gọi GitHub API, nhưng chưa chắc bị revoke
  ERROR
}
enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DeploymentStatus {
  QUEUED
  PULLING
  BUILDING
  DEPLOYING
  SUCCESS
  FAILED
  CANCELED
}

enum DeploymentTrigger {
  // MANUAL: user bấm deploy trên dashboard
  MANUAL
  // GITHUB_PUSH: GitHub webhook gọi về sau khi push code
  GITHUB_PUSH
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum LogStream {
  SYSTEM // log do platform tự ghi
  STDOUT // output bình thường từ command
  STDERR // output lỗi/cảnh báo từ command
}

enum EnvScope {
  BUILD // dùng khi docker build
  RUNTIME // dùng khi docker run
  BOTH // dùng cả 2
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  theme Theme @default(LIGHT)
  language Language @default(EN)

  passwordHash String?

  role UserRole @default(USER)

  githubConnection GithubConnection?
  projects         Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model GithubConnection {
  id     String @id @default(cuid())
  userId String @unique

  // Quan hệ 1-1 với User
  // Nếu user bị xóa thì GitHub connection cũng bị xóa
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ID thật của GitHub user
  // Lấy từ GitHub API: githubUser.id
  // Dùng để định danh account GitHub, ổn định hơn username

  githubUserId String @unique
  username     String
  displayName  String?
  avatarUrl    String? 

  // Không lưu access token plain text.
  // BE nên encrypt trước khi lưu.
  accessTokenEncrypted String

  // Scope mà user đã cấp cho OAuth app
  // Ví dụ: "repo,user:email"
  scopes String?

  status GithubConnectionStatus @default(CONNECTED)

  // Nếu token bị revoke hoặc lỗi OAuth nghiêm trọng thì lưu thời điểm này
  revokedAt DateTime?

  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name String

  // Slug dùng cho URL nội bộ
  slug String

  // Repo info lấy từ GitHub API, không nên cho user tự gõ fullName.
  // Ví dụ: "khoascada/wordy"
  repoFullName String
  repoOwner    String
  repoName     String
  repoUrl      String
  githubRepoId String?

  githubDefaultBranch String 
  deployBranch String 

  // Thư mục gốc của app trong repo
  // Với repo bình thường thì là "."
  // Với monorepo có thể là "apps/web"
  rootDirectory String @default(".")

  // Đường dẫn Dockerfile trong repo
  // Mặc định là "Dockerfile"
  // Nếu app nằm trong folder con có thể là "apps/web/Dockerfile"
  dockerfilePath String @default("Dockerfile")

  // Build context cho docker build
  // Thường là "."
  // Ví dụ command: docker build -f Dockerfile .
  buildContext   String @default(".")

  // Cách platform chạy command deploy
  // Phase 0.5 dùng LOCAL: chạy trực tiếp trên VPS hiện tại
  // Phase 1 dùng SSH: chạy command qua VPS khác
  runnerType RunnerType @default(LOCAL)

  // Đường dẫn repo được clone trên VPS
  // Phase 0.5 dùng field này
  // Ví dụ: "/var/mini-deploy/apps/wordy"
  localRepoPath String?

  // Phase 1 dùng sau
  sshHost String?
  sshPort Int?    @default(22)
  sshUser String?
  sshKeyEncrypted String?

  // Runtime config
  // Port mà app chạy bên trong container
  containerPort Int  @default(3000)
  // Port public trên VPS
  hostPort      Int? @unique

  containerName String? @unique
  imageName     String?

  autoDeploy Boolean @default(true)

  // GitHub webhook
  webhookId              String?
  webhookSecretEncrypted String?

  status ProjectStatus @default(ACTIVE)


  // nói vs prisma rằng project có thể chứa nhiều deployment (match vs project ở Deployment)
  deployments   Deployment[]    @relation("ProjectDeployments")
  logs          DeploymentLog[]
  envVars       EnvVar[]

  // Các webhook event nhận được từ GitHub
  webhookEvents WebhookEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, slug])
  @@unique([ownerId, githubRepoId])
  @@index([ownerId])
  @@index([githubRepoId])
}

model Deployment {
  id String @id @default(cuid())

  projectId String
  project   Project @relation("ProjectDeployments", fields: [projectId], references: [id], onDelete: Cascade)

  // Số thứ tự deploy trong từng project: 1, 2, 3...
  deploymentNumber Int

  // Deployment này được trigger bằng cách nào

  trigger DeploymentTrigger
  // Trạng thái hiện tại của deployment
  status  DeploymentStatus @default(QUEUED)

  branch String

  commitSha         String?
  commitMessage     String?
  commitAuthorName  String?
  commitAuthorEmail String?

  /// ID của request webhook do GitHub gửi
  /// GitHub gửi header: X-GitHub-Delivery
  ///
  /// Dùng để chống xử lý trùng webhook.
  /// Nếu GitHub retry cùng một webhook, mình có thể check delivery id này đã tồn tại chưa.
  githubDeliveryId String? @unique

  /// Docker image tag được build ở deployment này
  /// Ví dụ:
  /// "mini-deploy/wordy-frontend:deploy-12"
  ///
  /// Project.imageName chỉ lưu tên image base.
  /// Deployment.imageTag lưu tag cụ thể của lần deploy này.
  imageTag    String?
  /// Docker container id sau khi chạy thành công
  /// Ví dụ: "a8f9c1..."
  /// Không bắt buộc, nhưng hữu ích để debug
  containerId String?

  errorMessage String?

  // Thời điểm deployment được đưa vào queue
  queuedAt   DateTime  @default(now())
  // Thời điểm worker bắt đầu chạy deployment
  startedAt  DateTime?
  // Thời điểm deployment kết thúc, dù success hay failed
  finishedAt DateTime?
  // Tổng thời gian deploy, tính bằng milliseconds
  durationMs Int?

  logs DeploymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, deploymentNumber])
  @@index([projectId, createdAt])
  @@index([status])
}

model DeploymentLog {
  id String @id @default(cuid())

  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  // Denormalize projectId để query log theo project nhanh hơn
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // seq giúp FE render log đúng thứ tự
  /// Ví dụ:
  /// seq = 1: Starting deployment...
  /// seq = 2: Running git fetch...
  /// seq = 3: Building docker image...
  seq Int
  // Mức độ log
  level  LogLevel  @default(INFO)
  // Log này đến từ nguồn nào
  stream LogStream @default(SYSTEM)

  message String

  createdAt DateTime @default(now())

  @@unique([deploymentId, seq])
  @@index([projectId, createdAt])
}

model EnvVar {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Tên biến môi trường : DATABASE_URL,...
  key String

  // Phase 2 dùng chính thức.
  // Giá trị env đã được mã hóa
  // JSON string chứa toàn bộ encrypted envelope:
  // {
  //   "alg": "AES-256-GCM",
  //   "kid": 1,
  //   "iv": "...",
  //   "tag": "...",
  //   "ciphertext": "..."
  // }
  valueEncrypted String

  // Env này dùng ở giai đoạn nào
  scope EnvScope @default(BOTH)

  // cho phép tắt mà ko cần xóa khỏi DB
  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Trong một project, không nên có 2 env cùng key và cùng scope
  @@unique([projectId, key, scope])
}

model WebhookEvent {
  /// Primary key nội bộ của webhook event
  id String @id @default(cuid())

  /// Project liên quan tới webhook này
  ///
  /// Có thể null vì một số trường hợp:
  /// - GitHub gửi event "ping" khi mới tạo webhook
  /// - BE chưa tìm được project từ repository.id
  /// - Webhook sai repo / repo đã bị xóa khỏi hệ thống
  projectId String?

  /// Quan hệ tới Project
  /// Nếu project bị xóa thì webhook event vẫn có thể được giữ lại,
  /// nhưng projectId sẽ bị set null
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  /// ID duy nhất của lần GitHub gửi webhook
  ///
  /// Lấy từ header:
  /// X-GitHub-Delivery
  ///
  /// Dùng để chống xử lý trùng.
  /// Nếu GitHub retry cùng một webhook, delivery id vẫn giống nhau.
  githubDeliveryId String @unique

  /// Tên event GitHub gửi về
  ///
  /// Lấy từ header:
  /// X-GitHub-Event
  ///
  /// Ví dụ:
  /// "push"
  /// "ping"
  /// "pull_request"
  /// "create"
  /// "delete"
  eventName String

  /// Action cụ thể của event, nếu có
  ///
  /// Một số event như pull_request sẽ có action:
  /// "opened", "closed", "synchronize"
  ///
  /// Với push event thường không có action, nên nullable
  action String?

  /// Signature GitHub gửi lên
  ///
  /// Lấy từ header:
  /// X-Hub-Signature-256
  ///
  /// Ví dụ:
  /// "sha256=abc123..."
  ///
  /// Lưu lại để debug, không dùng thay webhook secret.
  signature String?

  /// Kết quả verify signature
  ///
  /// true: request được xác minh là đúng từ GitHub
  /// false: signature sai hoặc thiếu
  isVerified Boolean @default(false)

  /// Payload JSON GitHub gửi về
  ///
  /// Dùng để debug hoặc inspect lại webhook.
  /// Ví dụ payload push có:
  /// - ref
  /// - repository.id
  /// - repository.full_name
  /// - head_commit.id
  /// - head_commit.message
  payload Json

  /// Thời điểm BE nhận webhook
  receivedAt DateTime @default(now())

  /// Thời điểm BE xử lý xong webhook
  ///
  /// Có thể null nếu:
  /// - webhook mới nhận nhưng chưa xử lý xong
  /// - verify failed
  /// - bị duplicate nên bỏ qua
  processedAt DateTime?

  /// Lỗi xảy ra khi xử lý webhook
  ///
  /// Ví dụ:
  /// "Invalid signature"
  /// "Project not found"
  /// "Branch dev does not match deployBranch main"
  /// "Duplicate delivery id"
  errorMessage String?

  /// Tối ưu query webhook theo project
  @@index([projectId])

  /// Tối ưu query theo loại event
  /// Ví dụ xem tất cả event push/ping
  @@index([eventName])

  /// Tối ưu query webhook gần đây
  @@index([receivedAt])
}
